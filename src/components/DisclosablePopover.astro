---
interface Props {
  buttonText?: string
}
const { buttonText } = Astro.props
---

<button class="sign-in" popovertarget="disclose" popovertargetaction="toggle">{ buttonText }</button>
<div popover="auto" id="disclose" class="disclosure">
  <div class="disclosure__content">
    <!-- <header>
      <span>{ buttonText }</span>
    </header> -->
    <div class="content">
      <slot />
      <button popovertarget="disclose" popovertargetaction="close">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M6 18 18 6M6 6l12 12"
          />
        </svg>
      </button>
    </div>
  </div>
</div>

<style is:global>
  [data-area='center'] {
  #disclose,
  .disclosure__content {
    position-area: center;
  }
}

[data-area='top'] {
  #disclose,
  .disclosure__content {
    position-area: center top;
    bottom: anchor(bottom);
  }
}

[data-area='top-right'] {
  #disclose,
  .disclosure__content {
    left: anchor(left);
    bottom: anchor(bottom);
  }
}

[data-area='right'] {
  #disclose,
  .disclosure__content {
    position-area: right center;
    left: anchor(left);
  }
}

[data-area='bottom'] {
  #disclose,
  .disclosure__content {
    position-area: center bottom;
    top: anchor(top);
  }
}

[data-area='bottom-left'] {
  #disclose,
  .disclosure__content {
    top: anchor(top);
    right: anchor(right);
  }
}

[data-area='left'] {
  #disclose,
  .disclosure__content {
    position-area: left center;
    right: anchor(right);
  }
}

[data-area='top-left'] {
  #disclose,
  .disclosure__content {
    bottom: anchor(bottom);
    right: anchor(right);
  }
}

[data-area='bottom-right'] {
  #disclose,
  .disclosure__content {
    top: anchor(top);
    left: anchor(left);
  }
}
</style>

<style>
  :root{
    --sw: 160px;
    --sh: 48px;
    --ew: 600px;
    --eh: calc(var(--sh) + 16px);
    --base: hsl(
      var(--tint, 214) var(--saturated, 0%) 27% / calc(var(--alpha, 4) * 1%)
    );
    --shade: hsl(from var(--base) calc(h + 8) 25 calc(l - 5));
    --spread: 4;
    --s1: calc((var(--spread) * 1px) * pow(2, 0));
    --s2: calc((var(--spread) * 1px) * pow(2, 1));
    --s3: calc((var(--spread) * 1px) * pow(2, 2));
    --s4: calc((var(--spread) * 1px) * pow(2, 3));
    --s5: calc((var(--spread) * 1px) * pow(2, 4));
    /* this becomes the angle of spread, -1 through to 1 */
    --x: 0;
    --perfect-shadow: 0 0 0 1px var(--base), 0 1px 1px -0.5px var(--shade),
      calc(var(--s1) * var(--x)) var(--s1) var(--s1) calc(var(--s1) * -0.5)
        var(--shade),
      calc(var(--s2) * var(--x)) var(--s2) var(--s2) calc(var(--s2) * -0.5)
        var(--shade),
      calc(var(--s3) * var(--x)) var(--s3) var(--s3) calc(var(--s3) * -0.5)
        var(--base),
      calc(var(--s4) * var(--x)) var(--s4) var(--s4) calc(var(--s4) * -0.5)
        var(--base),
      calc(var(--s5) * var(--x)) var(--s5) var(--s5) calc(var(--s5) * -0.5)
        var(--base);
    --border: color-mix(in lch, canvasText, transparent 90%);
    --border-size: 4;
    --hr: color-mix(in lch, canvas, canvasText 10%);
    --speed: 0.3s;
    --starting: color-mix(in lch, canvas, canvasText 20%);
    --text: canvasText;
    --blur: 8;
    --saturate: 2.8;
    --brightness: 1.25;
    --contrast: 1;
  }
  [popovertargetaction='close'] {
    outline-offset: -0.875rem;
  }

/* The trigger button that starts it off */
.sign-in {
  position: absolute;
  width: var(--sw);
  height: var(--sh);
  border-radius: calc(var(--sh) * 0.5);
  border: 0;
  anchor-name: --control;
  box-shadow: 0px 0.5px 0.6px hsl(0 0% 0% / 0.06), 0px 1.8px 2.3px -0.5px hsl(0 0% 0% / 0.07), 0px 4.2px 5.3px -1.1px hsl(0 0% 0% / 0.09), 0px 9.7px 12.1px -1.6px hsl(0 0% 0% / 0.1);
  background: linear-gradient(light-dark(hsl(0 0% 98%), hsl(0 0% 12%)) 0 100%) padding-box;
  color: var(--text);
  padding: 0;
  left: calc(50% - (var(--sw) * 0.5));
  top: var(--display-height);
  z-index: 1;
  font-size: 16px;
  border: calc(var(--border-size) * 1px) solid light-dark(hsl(0 0% 0% / 0.1), hsl(0 0% 100% / 0.2));
  -webkit-backdrop-filter: blur(calc(var(--blur) * 1px)) saturate(var(--saturate, 2.8)) brightness(var(--brightness, 1.25)) contrast(var(--contrast, 1));
  backdrop-filter: blur(calc(var(--blur) * 1px)) saturate(var(--saturate, 2.8)) brightness(var(--brightness, 1.25)) contrast(var(--contrast, 1));
}

.disclosure {
  transition-property: width, height, border-radius;
  transition-duration: var(--duration);
  transition-timing-function: var(--ease);
}
#disclose {
  margin: 0;
  border: 0;
  padding: 0;
  /* outline: 4px solid red; */
  outline: none;
  inset: unset;
  position-anchor: --control;

  overflow: hidden;

  transition-property: display, overlay, color;
  transition-behavior: allow-discrete;
  transition-duration: var(--speed);
  transition-timing-function: var(--ease);
  height: var(--eh);
  width: var(--ew);

  background-color: var(--alignment) !important;

  &:popover-open {
    border-radius: 8px;
    background-color: canvas;
    color: canvasText;
    transition-duration: calc(2 * var(--speed));
    transition-timing-function: var(--ease-out);
  }
}
@starting-style {
  #disclose:popover-open {
    background-color: var(--starting);
    color: var(--text);
    width: anchor-size(--control width);
    height: anchor-size(--control height);
    border-radius: calc(var(--sh) * 0.5);
    box-shadow: 0 0 0 0 #0000;
  }
}

#disclose:popover-open {
  display: grid;
}

.disclosure {
  z-index: 999999;
  &:popover-open .disclosure__content {
    height: var(--eh);
    width: var(--ew);
    border-radius: 24px;
    box-shadow: 0px 0.5px 0.6px hsl(0 0% 0% / 0.06), 0px 1.8px 2.3px -0.5px hsl(0 0% 0% / 0.07), 0px 4.2px 5.3px -1.1px hsl(0 0% 0% / 0.09), 0px 9.7px 12.1px -1.6px hsl(0 0% 0% / 0.1);
    border: calc(var(--border-size) * 0.5px) solid light-dark(hsl(0 0% 0% / 0.1), hsl(0 0% 100% / 0.2));
    -webkit-backdrop-filter: blur(calc(var(--blur) * 1px)) saturate(var(--saturate, 2.8)) brightness(var(--brightness, 1.25)) contrast(var(--contrast, 1));
    backdrop-filter: blur(calc(var(--blur) * 1px)) saturate(var(--saturate, 2.8)) brightness(var(--brightness, 1.25)) contrast(var(--contrast, 1));
    background-color: canvas;
    color: canvasText;
    align-items: center;
    @starting-style {
      border-radius: calc(var(--sh) * 0.5);
      background-color: var(--starting);
      width: var(--sw);
      height: var(--sh);
    }
  }

  .disclosure__content {
    overflow: hidden;
    position: fixed;
    position-anchor: --control;
    border-radius: calc(var(--sh) * 0.5);
    background-color: var(--starting);
    box-shadow: 0 0 0 0 #0000;
    color: var(--text);
    display: flex;
    transition: display, height, width, border-radius, box-shadow,
      background-color, border-color, color;
    transition-duration: var(--speed);
    width: var(--sw);
    height: var(--sh);
  }
}

#disclose header {
  display: inline-flex;
  margin: 0 auto;
  transition: width var(--speed), height var(--speed);
  width: anchor-size(--control width);
  height: anchor-size(--control height);
  height: var(--sh);
  align-items: center;
  justify-content: center;
  border: 0;
  position: relative;
  transition: translate var(--speed);
  padding-inline: var(--padding);
}

#disclose header::after {
  content: '';
  position: absolute;
  bottom: 0.5rem;
  width: calc(var(--ew) * 2);
  left: 50%;
  opacity: 0;
  height: 1px;
  background: var(--hr);
  translate: -50% -50%;
  transition: opacity var(--speed);
}
#disclose:popover-open header::after {
  opacity: 1;
}
@starting-style {
  #disclose:popover-open header::after {
    opacity: 0;
  }
}

.content button {
  border-radius: var(--radius);
  border: 0;
  padding: 0;
  display: grid;
  place-items: center;
  justify-content: end;
  padding-right: var(--padding);
  cursor: pointer;
  aspect-ratio: 1;
  background: transparent;
}

.content button svg {
  width: 20px;
}

header span {
  transform-origin: 0 0;
  transition: scale var(--speed), translate var(--speed);
  display: flex;
  gap: var(--padding);
  font-size: 16px;
}

header span svg {
  width: 16px;
  transition: opacity var(--speed), scale var(--speed), translate var(--speed);
}

#disclose:popover-open header {
  translate: calc(var(--ew) * -0.5 + (50% + 0.25rem)) -0.5rem;
  transition-timing-function: ease;
  transition-duration: var(--speed);

  span {
    scale: 0.875;

    svg {
      opacity: 0;
      scale: 0;
      @starting-style {
        opacity: 1;
        scale: 1;
      }
    }

    @starting-style {
      scale: 1;
    }
  }

  @starting-style {
    translate: 0 0;
  }
}

#disclose:not(:popover-open) header {
  translate: 0 0;
}

.content {
  width: var(--ew);
  padding-inline: 16px;
  position: absolute;
  left: 50%;
  translate: -50% 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 0.875rem;
  opacity: 0;
  filter: blur(4px);
  transition: translate var(--speed), opacity var(--speed), filter var(--speed);
}

#disclose:popover-open .content {
  opacity: 1;
  translate: -50% 0;
  filter: blur(0);
}

@starting-style {
  #disclose:popover-open .content {
    opacity: 0;
    translate: -50% 2rem;
    filter: blur(4px);
  }
}


.disclosure button:not(.sign-in) {
  padding: calc(var(--padding) * 1.25) 1rem;
  border-radius: var(--radius);
  border: 0;
}



/* Outline the popover when focussed */
.sign-in:focus-visible + [popover] {
  outline: 1px solid canvasText;
}
</style>